# Values are capped at 1 for colour intensity.
# NA outcome or policy values are yellow.
# -----------------------------
blue_pal = grDevices::colorRampPalette(c("lightblue", "blue"))(101)
red_pal  = grDevices::colorRampPalette(c("pink", "red"))(101)
y_plot_df = outcome_long %>%
left_join(policy_outcome_map, by = "outcome") %>%
left_join(
policy_long,
by = c("country", "date", "policy")
) %>%
mutate(
value_capped = case_when(
is.na(value) ~ NA_real_,
value >= 1 ~ 1,
TRUE ~ value
),
value_scaled = value_capped / 1,
intensity_index = case_when(
is.na(value_scaled) ~ NA_integer_,
TRUE ~ pmin(
101L,
pmax(
1L,
as.integer(round(value_scaled * 100)) + 1L
)
)
),
fill_colour = case_when(
is.na(value) ~ "yellow",
is.na(policy_on) ~ "yellow",
policy_on == 0 ~ blue_pal[intensity_index],
policy_on == 1 ~ red_pal[intensity_index],
TRUE ~ "yellow"
),
country = factor(country, levels = country_levels),
panel_label = factor(
panel_label,
levels = policy_outcome_map$panel_label
)
)
p_y = ggplot(
y_plot_df,
aes(x = date, y = country, fill = fill_colour)
) +
geom_tile() +
facet_wrap(~ panel_label, nrow = 1) +
scale_fill_identity() +
labs(
title = paste0(
"Y: outcome tensor values through ",
time_horizon,
" using outcomes at t + ",
delay_days,
" days"
),
x = "Policy date",
y = "Country"
) +
theme_minimal() +
theme(
axis.text.y = element_text(size = 5),
axis.text.x = element_text(angle = 45, hjust = 1),
panel.grid = element_blank(),
strip.text = element_text(face = "bold", size = 8),
legend.position = "none"
)
print(p_y)
# -----------------------------
# Optional saves
# -----------------------------
ggsave(
filename = paste0(
"Omega_plot_until_",
time_horizon,
"_delay_",
delay_days,
".png"
),
plot = p_omega,
width = 16,
height = 8,
dpi = 300
)
ggsave(
filename = paste0(
"Y_plot_until_",
time_horizon,
"_delay_",
delay_days,
".png"
),
plot = p_y,
width = 16,
height = 8,
dpi = 300
)
cat("Saved Omega and Y plots.\n")
