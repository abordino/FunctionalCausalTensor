)
cat("\nCountries requested but not found in OWID:\n")
print(missing_countries)
if (length(missing_countries) > 0L) {
stop("Some requested countries are not present in OWID. Check country names.")
}
owid_base = owid_raw %>%
mutate(
date = as.Date(date),
location = as.character(location)
) %>%
filter(
location %in% candidate_countries,
date >= min(period_dates$window_start),
date <= max(period_dates$window_end),
!str_starts(iso_code, "OWID_")
) %>%
transmute(
country = location,
iso_code,
date,
population = as.numeric(population),
stringency_index = as.numeric(stringency_index),
new_deaths_smoothed = as.numeric(new_deaths_smoothed)
)
cat("\nLoaded fixed-subset OWID data.\n")
cat("Countries:", n_distinct(owid_base$country), "\n")
cat(
"Date range:",
format(min(owid_base$date, na.rm = TRUE)),
"to",
format(max(owid_base$date, na.rm = TRUE)),
"\n"
)
## ------------------------------------------------------------
## 2. Build selected long data
## ------------------------------------------------------------
selected_matrix_data = selected_period_country_map %>%
select(
period_index,
period_name,
period_label,
window_start,
window_end,
country,
country_slot,
tensor_row,
row,
row_state_name
) %>%
inner_join(
owid_base,
by = "country"
) %>%
filter(
date >= window_start,
date <= window_end
) %>%
mutate(
relative_day = as.integer(date - window_start) + 1L,
policy_value = stringency_index,
policy_on = as.integer(
!is.na(stringency_index) &
stringency_index >= policy_threshold
),
policy_status = if_else(policy_on == 1L, "On", "Off"),
deaths_raw = new_deaths_smoothed,
deaths_nonnegative = pmax(new_deaths_smoothed, 0),
deaths_log1p = log1p(deaths_nonnegative),
deaths_value = if (isTRUE(use_log1p_deaths)) {
deaths_log1p
} else {
deaths_raw
}
) %>%
arrange(
period_index,
country_slot,
relative_day
)
## Sanity check: each period-country must have exactly period_length_days rows.
coverage_check = selected_matrix_data %>%
group_by(period_index, country_slot, country) %>%
summarize(
n_days = n_distinct(date),
date_min = min(date),
date_max = max(date),
.groups = "drop"
)
bad_coverage = coverage_check %>%
filter(n_days != period_length_days)
if (nrow(bad_coverage) > 0L) {
cat("\nBad coverage rows:\n")
print(bad_coverage, n = Inf)
stop("At least one period-country does not have the required number of days.")
}
cat("\nCoverage check passed.\n")
print(coverage_check, n = Inf)
## ------------------------------------------------------------
## 3. Build tensor object
##
## Structure:
##   country_top_to_bottom x relative_day x period
##
## Row 1 = row_01 = top row.
## ------------------------------------------------------------
make_fixed_owid_tensor = function(
selected_data,
period_dates,
use_log1p_deaths = FALSE
) {
n_country = K_countries_per_period
n_day = period_length_days
n_period = nrow(period_dates)
country_dim_names = paste0("country_", seq_len(n_country))
day_dim_names = paste0("day_", seq_len(n_day))
period_dim_names = paste0("period_", seq_len(n_period))
deaths_raw_array = array(
NA_real_,
dim = c(n_country, n_day, n_period),
dimnames = list(
country_top_to_bottom = country_dim_names,
relative_day = day_dim_names,
period = period_dim_names
)
)
deaths_log1p_array = array(
NA_real_,
dim = c(n_country, n_day, n_period),
dimnames = list(
country_top_to_bottom = country_dim_names,
relative_day = day_dim_names,
period = period_dim_names
)
)
deaths_array = array(
NA_real_,
dim = c(n_country, n_day, n_period),
dimnames = list(
country_top_to_bottom = country_dim_names,
relative_day = day_dim_names,
period = period_dim_names
)
)
policy_array = array(
NA_integer_,
dim = c(n_country, n_day, n_period),
dimnames = list(
country_top_to_bottom = country_dim_names,
relative_day = day_dim_names,
period = period_dim_names
)
)
stringency_array = array(
NA_real_,
dim = c(n_country, n_day, n_period),
dimnames = list(
country_top_to_bottom = country_dim_names,
relative_day = day_dim_names,
period = period_dim_names
)
)
country_order = vector("list", n_period)
date_order = vector("list", n_period)
names(country_order) = period_dim_names
names(date_order) = period_dim_names
for (p in seq_len(n_period)) {
for (r in seq_len(n_country)) {
d_pr = selected_data %>%
filter(
period_index == p,
country_slot == r
) %>%
arrange(relative_day)
if (nrow(d_pr) != n_day) {
stop(
"Tensor construction failed for period ",
p,
", row ",
r,
": expected ",
n_day,
" days but found ",
nrow(d_pr),
"."
)
}
deaths_raw_array[r, , p] = d_pr$deaths_raw
deaths_log1p_array[r, , p] = d_pr$deaths_log1p
deaths_array[r, , p] = if (isTRUE(use_log1p_deaths)) {
d_pr$deaths_log1p
} else {
d_pr$deaths_raw
}
policy_array[r, , p] = d_pr$policy_on
stringency_array[r, , p] = d_pr$stringency_index
}
country_order[[p]] = selected_data %>%
filter(period_index == p) %>%
distinct(
country_slot,
tensor_row,
row,
country,
row_state_name,
period_index,
period_name,
period_label,
window_start,
window_end
) %>%
arrange(country_slot)
date_order[[p]] = selected_data %>%
filter(period_index == p) %>%
distinct(
relative_day,
date
) %>%
arrange(relative_day)
}
if (isTRUE(use_log1p_deaths)) {
outcome_name = "log1p_new_deaths_smoothed"
outcome_transform = "log1p(pmax(new_deaths_smoothed, 0))"
} else {
outcome_name = "new_deaths_smoothed"
outcome_transform = "none"
}
list(
policy_group = policy_code,
policy_name = policy_name,
policy_col = policy_col,
policy_threshold = policy_threshold,
outcome = outcome_name,
outcome_raw = "new_deaths_smoothed",
outcome_transform = outcome_transform,
use_log1p_deaths = use_log1p_deaths,
structure = "country_top_to_bottom x relative_day x period",
row_meaning = "Row 1 is row_01 and is the top country in the plot; larger row numbers move downward.",
deaths_raw = deaths_raw_array,
deaths_log1p = deaths_log1p_array,
deaths = deaths_array,
policy_on = policy_array,
stringency_index = stringency_array,
country_order = country_order,
date_order = date_order,
period_dates = period_dates,
selected_matrix_data = selected_data,
global_death_min_raw = floor(min(deaths_raw_array, na.rm = TRUE)),
global_death_max_raw = ceiling(max(deaths_raw_array, na.rm = TRUE)),
global_death_min = floor(min(deaths_array, na.rm = TRUE)),
global_death_max = ceiling(max(deaths_array, na.rm = TRUE)),
fill_values = c(
"Off" = "blue",
"On" = "red",
"Missing" = "green"
)
)
}
A = make_fixed_owid_tensor(
selected_data = selected_matrix_data,
period_dates = period_dates,
use_log1p_deaths = use_log1p_deaths
)
## You asked for A1, A2, A3 as at the end of your later file.
## Since this script has one fixed subset and one policy, these are aliases
## with the same data structure, so downstream code expecting A1/A2/A3 works.
A1 = A
A2 = A
A3 = A
## ------------------------------------------------------------
## 4. Print tensor summaries
## ------------------------------------------------------------
cat("\n============================================================\n")
cat("Tensor dimensions\n")
cat("============================================================\n")
cat("A1$deaths dimensions: country_top_to_bottom x relative_day x period\n")
print(dim(A1$deaths))
cat("\nA1$policy_on dimensions: country_top_to_bottom x relative_day x period\n")
print(dim(A1$policy_on))
cat("\n============================================================\n")
cat("Country order by period\n")
cat("============================================================\n")
for (p in names(A1$country_order)) {
cat("\n", p, "\n", sep = "")
print(
A1$country_order[[p]] %>%
select(
country_slot,
row,
country,
period_label
),
n = Inf
)
}
cat("\n============================================================\n")
cat("Death summary by period and country\n")
cat("============================================================\n")
selected_matrix_data %>%
group_by(period_index, country_slot, country) %>%
summarize(
n_days = n(),
n_missing_deaths = sum(is.na(deaths_raw)),
n_positive_deaths = sum(!is.na(deaths_raw) & deaths_raw > 0),
share_positive_deaths = round(n_positive_deaths / n_days, 2),
mean_deaths = round(mean(deaths_raw, na.rm = TRUE), 2),
median_positive_deaths = {
x = deaths_raw[!is.na(deaths_raw) & deaths_raw > 0]
if (length(x) == 0L) NA_real_ else round(median(x), 2)
},
p95_deaths = round(
as.numeric(quantile(deaths_raw, 0.95, na.rm = TRUE, names = FALSE)),
2
),
max_deaths = round(max(deaths_raw, na.rm = TRUE), 2),
.groups = "drop"
) %>%
arrange(period_index, country_slot) %>%
print(n = Inf)
## ------------------------------------------------------------
## 5. Plot policy matrices
##
## Blue = Off
## Red  = On
## Green = missing stringency
## ------------------------------------------------------------
plot_policy_matrix_from_A = function(A, period_i) {
period_name_i = paste0("period_", period_i)
country_labs = A$country_order[[period_name_i]] %>%
arrange(country_slot)
date_labs = A$date_order[[period_name_i]] %>%
arrange(relative_day)
policy_mat = A$policy_on[, , period_i, drop = FALSE]
stringency_mat = A$stringency_index[, , period_i, drop = FALSE]
d_plot = expand_grid(
country_slot = seq_len(dim(A$policy_on)[1]),
relative_day = seq_len(dim(A$policy_on)[2])
) %>%
mutate(
country = country_labs$country[country_slot],
date = date_labs$date[relative_day],
policy_on = as.integer(A$policy_on[cbind(country_slot, relative_day, period_i)]),
stringency_index = as.numeric(A$stringency_index[cbind(country_slot, relative_day, period_i)]),
policy_status = case_when(
is.na(stringency_index) ~ "Missing",
policy_on == 1L ~ "On",
TRUE ~ "Off"
)
)
ggplot(
d_plot,
aes(
x = relative_day,
y = country_slot,
fill = policy_status
)
) +
geom_tile(width = 1, height = 0.95) +
scale_fill_manual(
values = c(
"Off" = "blue",
"On" = "red",
"Missing" = "green"
),
drop = FALSE
) +
scale_y_reverse(
breaks = country_labs$country_slot,
labels = country_labs$country
) +
scale_x_continuous(
breaks = pretty(d_plot$relative_day),
limits = c(1, dim(A$policy_on)[2]),
expand = c(0, 0)
) +
labs(
title = paste0("Policy On/Off matrix: ", A$policy_name),
subtitle = paste0(
unique(country_labs$period_label),
"\nBlue = Off, red = On"
),
x = "Relative day in period",
y = NULL,
fill = "Policy status"
) +
theme_minimal(base_size = 10) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
axis.text.y = element_text(size = 8),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
legend.position = "right"
)
}
for (p in seq_len(dim(A1$policy_on)[3])) {
print(plot_policy_matrix_from_A(A1, p))
}
## ------------------------------------------------------------
## 6. Optional: plot deaths matrix
##
## Blue gradient = policy Off
## Red gradient  = policy On
## Green = missing deaths
## Stronger color = higher deaths
## ------------------------------------------------------------
safe_quantile = function(x, prob) {
x = x[!is.na(x)]
if (length(x) == 0L) {
NA_real_
} else {
as.numeric(quantile(x, probs = prob, na.rm = TRUE, names = FALSE))
}
}
plot_deaths_matrix_from_A = function(A, period_i) {
period_name_i = paste0("period_", period_i)
country_labs = A$country_order[[period_name_i]] %>%
arrange(country_slot)
date_labs = A$date_order[[period_name_i]] %>%
arrange(relative_day)
d_plot = expand_grid(
country_slot = seq_len(dim(A$deaths)[1]),
relative_day = seq_len(dim(A$deaths)[2])
) %>%
mutate(
country = country_labs$country[country_slot],
date = date_labs$date[relative_day],
deaths_value = as.numeric(A$deaths[cbind(country_slot, relative_day, period_i)]),
policy_on = as.integer(A$policy_on[cbind(country_slot, relative_day, period_i)]),
policy_status = if_else(policy_on == 1L, "On", "Off")
)
scale_max = safe_quantile(d_plot$deaths_value, 0.95)
if (is.na(scale_max) || is.infinite(scale_max) || scale_max <= 0) {
scale_max = max(d_plot$deaths_value, na.rm = TRUE)
}
if (is.na(scale_max) || is.infinite(scale_max) || scale_max <= 0) {
scale_max = 1
}
d_plot = d_plot %>%
mutate(
Y_scaled = case_when(
is.na(deaths_value) ~ NA_real_,
TRUE ~ pmin(pmax(deaths_value / scale_max, 0), 1)
),
fill_color = "green"
)
valid_off = !is.na(d_plot$Y_scaled) &
d_plot$policy_status == "Off"
d_plot$fill_color[valid_off] = rgb(
red = 1 - d_plot$Y_scaled[valid_off],
green = 1 - d_plot$Y_scaled[valid_off],
blue = 1,
maxColorValue = 1
)
valid_on = !is.na(d_plot$Y_scaled) &
d_plot$policy_status == "On"
d_plot$fill_color[valid_on] = rgb(
red = 1,
green = 1 - d_plot$Y_scaled[valid_on],
blue = 1 - d_plot$Y_scaled[valid_on],
maxColorValue = 1
)
ggplot(
d_plot,
aes(
x = relative_day,
y = country_slot,
fill = fill_color
)
) +
geom_tile(width = 1, height = 0.95) +
scale_fill_identity() +
scale_y_reverse(
breaks = country_labs$country_slot,
labels = country_labs$country
) +
scale_x_continuous(
breaks = pretty(d_plot$relative_day),
limits = c(1, dim(A$deaths)[2]),
expand = c(0, 0)
) +
labs(
title = paste0("Deaths matrix: ", A$outcome),
subtitle = paste0(
unique(country_labs$period_label),
"\nBlue = policy Off, red = policy On, stronger color = higher deaths"),
x = "Relative day in period",
y = NULL
) +
theme_minimal(base_size = 10) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
axis.text.y = element_text(size = 8),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),
legend.position = "none"
)
}
for (p in seq_len(dim(A1$deaths)[3])) {
print(plot_deaths_matrix_from_A(A1, p))
}
## ------------------------------------------------------------
## 7. Final object check
## ------------------------------------------------------------
cat("\nDone.\n")
cat("Objects available in memory:\n")
cat("  A\n")
cat("  A1\n")
cat("  A2\n")
cat("  A3\n")
cat("  selected_matrix_data\n")
cat("  selected_period_country_map\n")
cat("  period_dates\n")
