side = "U",
n1_vals = 200,
n2_vals = seq(50, 1000, by = 50),
r = 10,
p = 7,
svals = seq.int(1, 0.2, length.out = r),
tau = 0.15,
alpha_vals = c(1, 0),
B = 100
)
res_rect_U
