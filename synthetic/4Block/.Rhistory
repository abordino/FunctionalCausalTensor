}
}
# ------------------------------------------------------------
# Draw (a)/(b)/(c)/(d)
# ------------------------------------------------------------
label_draw = function(img, lab, x = 15, y = 35) {
info = image_info(img)
h = info$height
cex_val = max(1, h / 400)
img = image_draw(img)
par(mar = c(0, 0, 0, 0), xpd = NA, family = "HersheySans")
# soft white box behind text
w = strwidth(lab, cex = cex_val)
ht = strheight(lab, cex = cex_val)
rect(
x - 6, y - 1.6 * ht,
x + 6 + 1.1 * w, y + 6,
col = rgb(1, 1, 1, 0.7),
border = NA
)
text(
x, y,
labels = lab,
cex = cex_val,
col = "black",
adj = c(0, 1)
)
dev.off()
img
}
a = label_draw(imgs[1], "(a)")
b = label_draw(imgs[2], "(b)")
c = label_draw(imgs[3], "(c)")
d = label_draw(imgs[4], "(d)")
# ------------------------------------------------------------
# Helper: put image on white canvas of common cell size
# ------------------------------------------------------------
pad_to_cell = function(img, cell_width, cell_height) {
image_extent(
img,
geometry = paste0(cell_width, "x", cell_height),
gravity = "center",
color = "white"
)
}
info_list = lapply(list(a, b, c, d), image_info)
cell_width = max(sapply(info_list, function(z) z$width))
cell_height = max(sapply(info_list, function(z) z$height))
a_cell = pad_to_cell(a, cell_width, cell_height)
b_cell = pad_to_cell(b, cell_width, cell_height)
c_cell = pad_to_cell(c, cell_width, cell_height)
d_cell = pad_to_cell(d, cell_width, cell_height)
# ------------------------------------------------------------
# Layout:
#   top row    = (a) and (b)
#   bottom row = (c) and (d)
# ------------------------------------------------------------
top_row = image_append(image_join(a_cell, b_cell), stack = FALSE)
bottom_row = image_append(image_join(c_cell, d_cell), stack = FALSE)
combo = image_append(image_join(top_row, bottom_row), stack = TRUE)
image_write(combo, "figure/combined_2x2.png")
plot_mse_vs_K_pretty = function(sumdf, raw_df, file_png, main_title = NULL,
error_bar = c("ci95", "se", "sd", "none")) {
error_bar = match.arg(error_bar)
methods = c("oracle_local", "real_pool")
snr_vals = sort(unique(sumdf$SNR_target))
col_map = c(
oracle_local = "#f95919",
real_pool = "#1b9e77"
)
pch_map = c(
oracle_local = 20,
real_pool = 16
)
lab_map = c(
oracle_local = TeX(r"(Oracle local $A_3$)"),
real_pool = TeX(r"(Estimated pooled)")
)
lty_candidates = c(1, 2, 3, 4, 5, 6)
lty_map = setNames(lty_candidates[seq_along(snr_vals)], as.character(snr_vals))
Ks = sort(unique(sumdf$K))
err_col = switch(
error_bar,
ci95 = "CI95",
se = "SE",
sd = "SD",
none = NA_character_
)
if (error_bar == "none") {
sumdf$ERR = 0
} else {
sumdf$ERR = sumdf[[err_col]]
sumdf$ERR[!is.finite(sumdf$ERR)] = 0
}
pos_vals = c(
sumdf$MSE,
sumdf$MSE + sumdf$ERR
)
pos_vals = pos_vals[is.finite(pos_vals) & pos_vals > 0]
eps = if (length(pos_vals) > 0) min(pos_vals) * 0.5 else 1e-16
y_upper_all = log10(pmax(sumdf$MSE + sumdf$ERR, eps))
y_lower_all = log10(pmax(sumdf$MSE - sumdf$ERR, eps))
y_line_all = log10(pmax(sumdf$MSE, eps))
y_min = min(c(y_lower_all, y_line_all), na.rm = TRUE)
y_max = max(c(y_upper_all, y_line_all), na.rm = TRUE)
y_rng = diff(range(y_min, y_max))
if (!is.finite(y_rng) || y_rng == 0) {
y_rng = 1
}
cu_max = max(raw_df$c_u, na.rm = TRUE)
cell_min = min(raw_df$c_ell, na.rm = TRUE)
if (is.null(main_title)) {
main_title = TeX(r"($\log_{10}(MSE)$ vs.\ $K$)")
} else {
main_title = TeX(main_title)
}
error_label = switch(
error_bar,
ci95 = "95% Monte Carlo CI",
se = "Monte Carlo SE",
sd = "SD of squared errors",
none = "No error bars"
)
png(file_png, width = 1450, height = 650, res = 140, bg = "white")
on.exit(dev.off())
par(mar = c(5, 5, 4, 15), xpd = NA, bg = "white")
plot(
Ks,
rep(NA, length(Ks)),
ylim = c(
y_min - 0.08 * y_rng,
y_max + 0.18 * y_rng
),
xlab = TeX(r"($K$)"),
ylab = TeX(r"($\log_{10}(MSE)$)"),
main = main_title,
type = "n"
)
usr = par("usr")
rect(usr[1], usr[3], usr[2], usr[4], col = "white", border = NA)
grid(col = "white", lwd = 1.2)
box()
for (m in methods) {
for (snr in snr_vals) {
dm = sumdf[sumdf$method == m & sumdf$SNR_target == snr, ]
dm = dm[order(dm$K), ]
this_lty = lty_map[as.character(snr)]
y_line = log10(pmax(dm$MSE, eps))
lines(
dm$K,
y_line,
type = "b",
col = col_map[m],
pch = pch_map[m],
lty = this_lty,
lwd = 2
)
if (error_bar != "none") {
ok = is.finite(dm$ERR) & is.finite(dm$MSE) & dm$MSE > 0
if (any(ok)) {
y_low = log10(pmax(dm$MSE[ok] - dm$ERR[ok], eps))
y_high = log10(pmax(dm$MSE[ok] + dm$ERR[ok], eps))
pos = is.finite(y_low) & is.finite(y_high) & y_high > y_low
if (any(pos)) {
arrows(
x0 = dm$K[ok][pos],
y0 = y_low[pos],
x1 = dm$K[ok][pos],
y1 = y_high[pos],
angle = 90,
code = 3,
length = 0.03,
col = adjustcolor(col_map[m], alpha.f = 0.95),
lwd = 0.8,
lty = this_lty
)
}
}
}
}
}
text(
x = mean(range(Ks)),
y = y_max + 0.13 * y_rng,
labels = TeX(sprintf(
"$\\max c_u = %.4f$ \\ $\\min c_{\\ell} = %.4f$ \\ Error bars: %s",
cu_max, cell_min, error_label
)),
adj = c(0.5, 1),
cex = 0.80
)
x_leg = usr[2] + 0.08 * diff(usr[1:2])
legend(
x = x_leg,
y = usr[4],
legend = unname(lab_map[methods]),
col = col_map[methods],
pch = pch_map[methods],
lty = 1,
lwd = 2,
bty = "n",
title = TeX(r"(Method)")
)
legend(
x = x_leg,
y = usr[4] - 0.32 * diff(usr[3:4]),
legend = paste0("SNR = ", signif(1 / snr_vals, 3)),
col = "black",
lty = unname(lty_map[as.character(snr_vals)]),
lwd = 2,
bty = "n",
title = "SNR"
)
}
