rep(1,r)
seq(1, 0.2, r)
seq_along(1, 0.2, r)
seq(1, 0.2, r)
seq.int(1, 0.2, length.out = r)
#################
# Helpers
#################
rand_unit = function(n) {
x = rnorm(n)
x / sqrt(sum(x^2))
}
orth_frame = function(n, r) {
if (r < 1 || r > n) stop("Need 1 <= r <= n in orth_frame().")
qr.Q(qr(matrix(rnorm(n * r), n, r)))[, 1:r, drop = FALSE]
}
# Full orthonormal complement basis of span(U)
orth_complement_basis = function(U) {
n = nrow(U)
r = ncol(U)
Qfull = qr.Q(qr(U), complete = TRUE)
Qfull[, (r + 1):n, drop = FALSE]
}
# Orthogonal Procrustes alignment
procrustes_H = function(Uhat, U) {
s = svd(crossprod(Uhat, U))
s$u %*% t(s$v)
}
# Build X \in R^{n1 x p1} with orthonormal columns
# alpha = 1  => columns entirely in span(U)
# alpha = 0  => columns entirely in span(U)^\perp
# 0 < alpha < 1 => each column has the same in/out balance
#
# For 0 < alpha < 1, we need p1 <= min(r, n1-r).
# For alpha = 1, we only need p1 <= r.
# For alpha = 0, we only need p1 <= n1-r.
make_probe = function(U, p1, alpha, tol = 1e-12) {
n1 = nrow(U)
r  = ncol(U)
if (p1 < 1 || p1 > n1) stop("Need 1 <= p1 <= n1.")
if (alpha < -tol || alpha > 1 + tol) stop("alpha must be in [0,1].")
alpha = max(0, min(1, alpha))
if (alpha < 1 - tol && alpha > tol) {
if (p1 > min(r, n1 - r)) {
stop("For 0 < alpha < 1, need p1 <= min(r, n1-r).")
}
} else if (alpha >= 1 - tol) {
if (p1 > r) stop("For alpha = 1, need p1 <= r.")
} else {
if (p1 > n1 - r) stop("For alpha = 0, need p1 <= n1-r.")
}
if (alpha >= 1 - tol) {
A = orth_frame(r, p1)
X = U %*% A
return(X)
}
Uperp = orth_complement_basis(U)
if (alpha <= tol) {
B = orth_frame(n1 - r, p1)
X = Uperp %*% B
return(X)
}
A = orth_frame(r, p1)
B = orth_frame(n1 - r, p1)
X = U %*% (alpha * A) + Uperp %*% (sqrt(1 - alpha^2) * B)
X
}
sim_once = function(n1, n2, r, p1, svals, sigma, alpha) {
U = orth_frame(n1, r)
V = orth_frame(n2, r)
M = U %*% diag(svals, r, r) %*% t(V)
Y = M + matrix(rnorm(n1 * n2, sd = sigma), n1, n2)
s = svd(Y, nu = r, nv = r)
Uhat = s$u
H = procrustes_H(Uhat, U)
Uhat = Uhat %*% H
X = make_probe(U, p1, alpha)
# Frobenius norm of X^T (Uhat - U)
# For p1 = 1 this matches your old scalar-vector error exactly.
E = crossprod(X, Uhat - U)
err = sqrt(sum(E^2))
c(err = err)
}
run_grid = function(n1_vals, n2_vals, r, p1, svals, tau, alpha_vals, B = 500) {
out = vector("list", length(n1_vals) * length(n2_vals) * length(alpha_vals))
k = 1
for (n1 in n1_vals) {
for (n2 in n2_vals) {
print(n2)
nmax = max(n1, n2)
sr = min(svals)
sigma = tau * sr / sqrt(nmax)
for (alpha in alpha_vals) {
errs = replicate(
B,
sim_once(n1, n2, r, p1, svals, sigma, alpha)["err"]
)
out[[k]] = data.frame(
n1 = n1,
n2 = n2,
r = r,
p1 = p1,
alpha = alpha,
tau = tau,
sigma = sigma,
mean_err = mean(errs),
med_err = median(errs),
q90_err = unname(quantile(errs, 0.90)),
# same normalizations as before
norm_first = mean(errs) / (sigma / sr),
norm_second_n1 = mean(errs) / (sigma^2 * n1 / sr^2),
norm_second_nmax = mean(errs) / (sigma^2 * nmax / sr^2),
# optional per-column versions
mean_err_per_col = mean(errs) / sqrt(p1),
norm_first_per_col = mean(errs) / sqrt(p1) / (sigma / sr),
norm_second_n1_per_col = mean(errs) / sqrt(p1) / (sigma^2 * n1 / sr^2),
norm_second_nmax_per_col = mean(errs) / sqrt(p1) / (sigma^2 * nmax / sr^2)
)
k = k + 1
}
}
}
do.call(rbind, out)
}
#################
# Rectangular sim
#################
# Choose p1 subject to:
#   alpha = 1  -> p1 <= r
#   alpha = 0  -> p1 <= n1 - r
#   0 < alpha < 1 -> p1 <= min(r, n1 - r)
set.seed(231198)
res_rect = run_grid(
n1_vals = 200,
n2_vals = seq(50, 1000, by = 50),
r = 10,
p1 = 7,                    # new
svals = seq.int(1, 0.2, length.out = r),
tau = 0.15,
alpha_vals = c(1, 0),
B = 100
)
#################
# Helpers
#################
rand_unit = function(n) {
x = rnorm(n)
x / sqrt(sum(x^2))
}
orth_frame = function(n, r) {
if (r < 1 || r > n) stop("Need 1 <= r <= n in orth_frame().")
qr.Q(qr(matrix(rnorm(n * r), n, r)))[, 1:r, drop = FALSE]
}
# Full orthonormal complement basis of span(U)
orth_complement_basis = function(U) {
n = nrow(U)
r = ncol(U)
Qfull = qr.Q(qr(U), complete = TRUE)
Qfull[, (r + 1):n, drop = FALSE]
}
# Orthogonal Procrustes alignment
procrustes_H = function(Ahat, A) {
s = svd(crossprod(Ahat, A))
s$u %*% t(s$v)
}
# Build X \in R^{n x p} with orthonormal columns
# alpha = 1  => columns entirely in span(U)
# alpha = 0  => columns entirely in span(U)^\perp
# 0 < alpha < 1 => each column has the same in/out balance
#
# For 0 < alpha < 1, we need p <= min(r, n-r).
# For alpha = 1, we only need p <= r.
# For alpha = 0, we only need p <= n-r.
make_probe = function(U, p, alpha, tol = 1e-12) {
n = nrow(U)
r = ncol(U)
if (p < 1 || p > n) stop("Need 1 <= p <= n.")
if (alpha < -tol || alpha > 1 + tol) stop("alpha must be in [0,1].")
alpha = max(0, min(1, alpha))
if (alpha < 1 - tol && alpha > tol) {
if (p > min(r, n - r)) {
stop("For 0 < alpha < 1, need p <= min(r, n-r).")
}
} else if (alpha >= 1 - tol) {
if (p > r) stop("For alpha = 1, need p <= r.")
} else {
if (p > n - r) stop("For alpha = 0, need p <= n-r.")
}
if (alpha >= 1 - tol) {
A = orth_frame(r, p)
X = U %*% A
return(X)
}
Uperp = orth_complement_basis(U)
if (alpha <= tol) {
B = orth_frame(n - r, p)
X = Uperp %*% B
return(X)
}
A = orth_frame(r, p)
B = orth_frame(n - r, p)
X = U %*% (alpha * A) + Uperp %*% (sqrt(1 - alpha^2) * B)
X
}
# Safe diagonal matrix for signal singular values.
# Allows length(svals) <= r.
make_D = function(svals, r) {
if (length(svals) > r) stop("Need length(svals) <= r.")
D = diag(0, r, r)
diag(D)[1:length(svals)] = svals
D
}
#################
# One-run sims
#################
sim_once_U = function(n1, n2, r, p1, svals, sigma, alpha) {
U = orth_frame(n1, r)
V = orth_frame(n2, r)
D = make_D(svals, r)
M = U %*% D %*% t(V)
Y = M + matrix(rnorm(n1 * n2, sd = sigma), n1, n2)
s = svd(Y, nu = r, nv = r)
Uhat = s$u
H = procrustes_H(Uhat, U)
Uhat = Uhat %*% H
X = make_probe(U, p1, alpha)
# Frobenius norm of X^T (Uhat - U)
E = crossprod(X, Uhat - U)
err = sqrt(sum(E^2))
c(err = err)
}
sim_once_V = function(n1, n2, r, p2, svals, sigma, alpha) {
U = orth_frame(n1, r)
V = orth_frame(n2, r)
D = make_D(svals, r)
M = U %*% D %*% t(V)
Y = M + matrix(rnorm(n1 * n2, sd = sigma), n1, n2)
s = svd(Y, nu = r, nv = r)
Vhat = s$v
H = procrustes_H(Vhat, V)
Vhat = Vhat %*% H
Z = make_probe(V, p2, alpha)
# Frobenius norm of Z^T (Vhat - V)
E = crossprod(Z, Vhat - V)
err = sqrt(sum(E^2))
c(err = err)
}
#################
# Grid runners
#################
run_grid_U = function(n1_vals, n2_vals, r, p1, svals, tau, alpha_vals, B = 500) {
out = vector("list", length(n1_vals) * length(n2_vals) * length(alpha_vals))
k = 1
for (n1 in n1_vals) {
for (n2 in n2_vals) {
print(n2)
nmax = max(n1, n2)
sr = min(svals)
sigma = tau * sr / sqrt(nmax)
for (alpha in alpha_vals) {
errs = replicate(
B,
sim_once_U(n1, n2, r, p1, svals, sigma, alpha)["err"]
)
out[[k]] = data.frame(
side = "U",
n1 = n1,
n2 = n2,
r = r,
p = p1,
alpha = alpha,
tau = tau,
sigma = sigma,
mean_err = mean(errs),
med_err = median(errs),
q90_err = unname(quantile(errs, 0.90)),
norm_first = mean(errs) / (sigma / sr),
norm_second_dim = mean(errs) / (sigma^2 * n1 / sr^2),
norm_second_nmax = mean(errs) / (sigma^2 * nmax / sr^2),
mean_err_per_col = mean(errs) / sqrt(p1),
norm_first_per_col = mean(errs) / sqrt(p1) / (sigma / sr),
norm_second_dim_per_col = mean(errs) / sqrt(p1) / (sigma^2 * n1 / sr^2),
norm_second_nmax_per_col = mean(errs) / sqrt(p1) / (sigma^2 * nmax / sr^2)
)
k = k + 1
}
}
}
do.call(rbind, out)
}
run_grid_V = function(n1_vals, n2_vals, r, p2, svals, tau, alpha_vals, B = 500) {
out = vector("list", length(n1_vals) * length(n2_vals) * length(alpha_vals))
k = 1
for (n1 in n1_vals) {
for (n2 in n2_vals) {
print(n2)
nmax = max(n1, n2)
sr = min(svals)
sigma = tau * sr / sqrt(nmax)
for (alpha in alpha_vals) {
errs = replicate(
B,
sim_once_V(n1, n2, r, p2, svals, sigma, alpha)["err"]
)
out[[k]] = data.frame(
side = "V",
n1 = n1,
n2 = n2,
r = r,
p = p2,
alpha = alpha,
tau = tau,
sigma = sigma,
mean_err = mean(errs),
med_err = median(errs),
q90_err = unname(quantile(errs, 0.90)),
norm_first = mean(errs) / (sigma / sr),
norm_second_dim = mean(errs) / (sigma^2 * n2 / sr^2),
norm_second_nmax = mean(errs) / (sigma^2 * nmax / sr^2),
mean_err_per_col = mean(errs) / sqrt(p2),
norm_first_per_col = mean(errs) / sqrt(p2) / (sigma / sr),
norm_second_dim_per_col = mean(errs) / sqrt(p2) / (sigma^2 * n2 / sr^2),
norm_second_nmax_per_col = mean(errs) / sqrt(p2) / (sigma^2 * nmax / sr^2)
)
k = k + 1
}
}
}
do.call(rbind, out)
}
#################
# Unified runner
#################
run_grid = function(side = c("U", "V"),
n1_vals, n2_vals, r, p, svals, tau, alpha_vals, B = 500) {
side = match.arg(side)
if (side == "U") {
run_grid_U(
n1_vals = n1_vals,
n2_vals = n2_vals,
r = r,
p1 = p,
svals = svals,
tau = tau,
alpha_vals = alpha_vals,
B = B
)
} else {
run_grid_V(
n1_vals = n1_vals,
n2_vals = n2_vals,
r = r,
p2 = p,
svals = svals,
tau = tau,
alpha_vals = alpha_vals,
B = B
)
}
}
#################
# Rectangular sims
#################
